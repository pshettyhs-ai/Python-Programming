# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/

# Database files generated by projects (kept out of git, regenerated on run)
*.db
*.sqlite3

# Sensitive files - NEVER commit these
secret.key
.env
*.pem

# IDE
.vscode/
.idea/
*.swp

# OS files
.DS_Store
Thumbs.db

# Generated reports/exports from projects
*.csv
!sample_*.csv
*.pdf
!Images/**/*.pdf

# Logs
*.log
